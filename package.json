{
  "name": "janedeck",
  "version": "0.1.0",
  "private": true,
  "description": "A real-time multiplayer trivia game platform built with partyserver",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "docker:build": "docker build -t ghcr.io/therebelrobot/janedeck:local .",
    "docker:run": "docker run --rm -p 5173:5173 -v $(pwd)/.wrangler:/app/.wrangler ghcr.io/therebelrobot/janedeck:local",
    "docker:push": "docker buildx build --platform linux/amd64,linux/arm64 -t ghcr.io/therebelrobot/janedeck:latest --push .",
    "release:patch": "npm version patch -m \"chore: release v%s\" && git push && git push --tags",
    "release:minor": "npm version minor -m \"chore: release v%s\" && git push && git push --tags",
    "release:major": "npm version major -m \"chore: release v%s\" && git push && git push --tags",
    "release:tags": "git tag --sort=-v:refname | grep '^v'"
  },
  "keywords": [
    "partyserver",
    "trivia",
    "multiplayer",
    "real-time",
    "game"
  ],
  "license": "MIT",
  "dependencies": {
    "@cloudflare/vite-plugin": "^1.42.3",
    "framer-motion": "^12.42.0",
    "fuse.js": "^7.4.2",
    "nanoid": "^5.1.16",
    "partyserver": "^0.5.8",
    "partysocket": "^1.3.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.0",
    "wrangler": "^4.105.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260626.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "typescript": "^6.0.3",
    "vite": "^8.1.0"
  }
}